<!DOCTYPE html>
<html lang="hi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Deals</title>
    <style>
        .banner { background: #ff4500; color: white; padding: 20px; text-align: center; border-radius: 10px; margin-bottom: 15px; }
        .grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; padding: 10px; }
        .card { background: white; padding: 15px; border-radius: 10px; border: 1px solid #ddd; text-align: center; }
        .btn { display: block; background: #28a745; color: white; padding: 10px; text-decoration: none; border-radius: 5px; margin-top: 10px; font-weight: bold; }
    </style>
</head>
<body>

    <div class="banner"><h2 id="page-title">Loading...</h2></div>
    <div class="grid" id="product-container"></div>

    <script>
        // 1. यहाँ अपनी कैटेगरी का नाम सही लिखें (जैसे: 'amazon', 'ajio', 'bitli', 'hamaramall')
        const myCategory = 'amazon'; 
        
        document.getElementById('page-title').innerText = myCategory.toUpperCase() + " DEALS";

        fetch('products.json')
        .then(r => r.json())
        .then(data => {
            const container = document.getElementById('product-container');
            // डेटा को फिल्टर करें
            const items = data.filter(p => p.category.toLowerCase() === myCategory.toLowerCase());
            
            if (items.length === 0) {
                container.innerHTML = "<p>कोई प्रोडक्ट नहीं मिला।</p>";
            } else {
                container.innerHTML = items.map(p => `
                    <div class="card">
                        <div style="font-weight:bold; margin-bottom:5px;">${p.name}</div>
                        <div style="color:red; font-weight:bold;">${p.price}</div>
                        <a href="${p.link}" target="_blank" class="btn">Buy Now</a>
                    </div>
                `).join('');
            }
        })
        .catch(err => {
            document.getElementById('page-title').innerText = "Error";
            console.error(err);
        });
    </script>
</body>
</html>
